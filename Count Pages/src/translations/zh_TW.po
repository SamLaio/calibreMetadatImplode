msgstr "建立新欄位"

msgid "Count Pages"
msgstr "頁數統計"

msgid "&Estimate page/word counts"
msgstr "&估算頁數/字數"

msgid "&Download page/word counts - all sources"
msgstr "&從所有來源下載頁數/字數"

msgid "&Statistic totals for selected books"
msgstr "&選取書籍的統計總計"

